#!ipxe
# Linux via kernel + initrd (UEFI-friendly).
# Copy vmlinuz / initrd.img into services/webfs/htdocs/linux/ first.
set base http://${next-server}:8080
# Add your kernel parameters: root=, ip=dhcp, console=...
kernel ${base}/linux/vmlinuz initrd=initrd.img ip=dhcp console=tty0
initrd ${base}/linux/initrd.img
boot || goto failed
:failed
echo Kernel boot failed.
shell
