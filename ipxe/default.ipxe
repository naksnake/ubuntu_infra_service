#!ipxe
# Chain to the iPXE Manager dynamic boot menu.
# ${next-server} is provided by DHCP (TFTP_SERVER_IP / PXE_ROUTER_IP).
chain http://${next-server}:8091/menu.ipxe || goto fallback
:fallback
echo Failed to reach iPXE Manager at http://${next-server}:8091/menu.ipxe
echo Dropping to shell — type 'exit' to return to BIOS/UEFI.
shell
