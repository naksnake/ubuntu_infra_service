#!ipxe
# BIOS-oriented ISO sanboot (works for many Linux Live ISOs).
# Edit 'isofile' to match a file in data/webfs_share/ (served at /files/).
set isofile example.iso
set base http://${next-server}:8080
sanboot --no-describe ${base}/files/${isofile} || goto failed
exit
:failed
echo ISO sanboot failed (UEFI firmware cannot sanboot ISOs — use kernel+initrd).
shell
