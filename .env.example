# ==== Network settings ====
PXE_IFACE=eth1
WAN_IFACE=eth0
PXE_RANGE_START=192.168.100.10
PXE_RANGE_END=192.168.100.200
PXE_NETMASK=255.255.255.0
PXE_ROUTER_IP=192.168.100.1
WEBFS_HOST_IP=192.168.100.1
TFTP_SERVER_IP=192.168.100.1
DNS_SERVER=8.8.8.8

# ==== Ports ====
WEBFS_PORT=8080
IPXE_MANAGER_PORT=8091
CCP_PORT=8060
MONITOR_PORT=8090
MONITOR_REFRESH=30

# ==== iPXE Manager ====
# Optional: set a password to require login for the web UI and API.
# Leave blank to disable auth. /menu.ipxe always stays open for PXE clients.
IPXE_MANAGER_PASSWORD=

# ==== Cluster Control Panel (CCP) ====
# Web UI to run ClusterShell commands and Ansible playbooks across your nodes.
CCP_ADMIN_USER=admin
CCP_ADMIN_PASSWORD=changeme
# Set to 1 to seed a self-contained "localhost" demo node + sample scripts on
# first run, so you can try the panel before adding real SSH hosts.
CCP_DEMO=0
# CCP_SECRET_KEY (Flask session signing) is generated by deploy.sh on first run.
# Do NOT set it manually unless restoring from backup.
CCP_SECRET_KEY=

# ==== Monitor dashboard (login + RBAC) ====
# The dashboard now requires login. The admin account reuses CCP_ADMIN_USER /
# CCP_ADMIN_PASSWORD above. Optionally add a read-only viewer account (leave the
# password blank to disable it):
MONITOR_VIEWER_USER=viewer
MONITOR_VIEWER_PASSWORD=
MONITOR_SESSION_MINUTES=30       # session lifetime; sliding (resets on activity)
# MONITOR_SECRET_KEY is generated by deploy.sh on first run.
MONITOR_SECRET_KEY=
