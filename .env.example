# ==== Network settings ====
PXE_IFACE=eth1
WAN_IFACE=eth0
PXE_RANGE_START=192.168.100.10
PXE_RANGE_END=192.168.100.200
PXE_NETMASK=255.255.255.0
PXE_ROUTER_IP=192.168.100.1
WEBFS_HOST_IP=192.168.100.1
TFTP_SERVER_IP=192.168.100.1
DNS_SERVER=8.8.8.8

# ==== Ports ====
WEBFS_PORT=8080
IPXE_MANAGER_PORT=8091
AWX_HTTP_PORT=8052
MONITOR_PORT=8090
MONITOR_REFRESH=30

# ==== iPXE Manager ====
# Optional: set a password to require login for the web UI and API.
# Leave blank to disable auth. /menu.ipxe always stays open for PXE clients.
IPXE_MANAGER_PASSWORD=

# ==== AWX settings ====
# AWX_VERSION: check https://github.com/ansible/awx/releases for the latest
AWX_VERSION=23.9.0
AWX_ADMIN_USER=admin
AWX_ADMIN_PASSWORD=changeme
# AWX_DB_PASSWORD and AWX_SECRET_KEY are generated by deploy.sh on first run.
# Do NOT set them manually unless restoring from backup.
AWX_DB_PASSWORD=
AWX_SECRET_KEY=

# Optional: ISO name for BIOS-only sanboot (Linux Live ISO)
ISO_FILE=example.iso
